# 房屋租赁AI营销系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ========== 应用基础配置 ==========
BACKEND_PORT=8899
FRONTEND_URL=http://localhost:3000
DEBUG=True

# ========== DeepSeek API配置 ==========
# 必填：DeepSeek API密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxx
# 可选：DeepSeek API地址（默认 https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：使用的模型（默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# ========== 小红书MCP配置 ==========
# 可选：xiaohongshu-mcp服务地址（默认 http://localhost:18060）
XHS_MCP_URL=http://localhost:18060

# ========== 微信公众号配置 ==========
# 可选：微信公众号AppID（如需微信公众号草稿功能则填写）
WECHAT_APPID=
# 可选：微信公众号AppSecret（作为多账号兜底 / 首个种子账号来源）
WECHAT_APPSECRET=

# ========== 安全加密配置 ==========
# 可选：AppSecret 加密密钥（Fernet，44 字符 urlsafe base64）
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 留空则自动使用 backend/.encryption_key 回退文件（首次运行自动生成，已 gitignore）
ENCRYPTION_KEY=

# ========== 文件存储配置 ==========
# 可选：图片上传目录（默认 ./uploads）
UPLOAD_DIR=./uploads
# 可选：图片保留天数（默认 7 天）
IMAGE_RETENTION_DAYS=7
# 可选：单张图片最大大小（默认 10MB）
MAX_IMAGE_SIZE=10485760

# ========== 数据库配置 ==========
# 可选：数据库URL（默认 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./house_ai.db

# ========== 日志配置 ==========
# 可选：日志级别（默认 INFO）
LOG_LEVEL=INFO
# 可选：日志目录（默认 ./logs）
LOG_DIR=./logs

# ========== AI文案生成配置 ==========
# 可选：AI生成最大token数（默认 2000）
AI_MAX_TOKENS=2000
# 可选：AI生成温度参数（默认 0.7）
AI_TEMPERATURE=0.7
